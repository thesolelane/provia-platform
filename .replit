# .replit
# =====================================================
# REPLIT CONFIGURATION — DO NOT MODIFY
# This locks how Replit runs the application
# =====================================================

run = "npm start"
entrypoint = "server/index.js"
language = "nodejs"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-23_11"
packages = ["alsa-lib", "at-spi2-atk", "atk", "cairo", "chromium", "cups", "dbus", "expat", "glib", "gtk3", "libdrm", "libxkbcommon", "mesa", "nspr", "nss", "pango", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb"]

[env]
PORT = "3001"
NODE_ENV = "development"

[packager]
language = "nodejs"

[packager.features]
packageSearch = true
guessImports = true
enabledForHosting = false

[languages.javascript]
pattern = "**/{*.js,*.jsx,*.ts,*.tsx}"
syntax = "javascript"

[languages.javascript.languageServer]
start = "typescript-language-server --stdio"

[deployment]
run = ["sh", "-c", "npm start"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[agent]
expertMode = true
integrations = ["google-calendar:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server/index.js"
waitForPort = 5000

[userenv]

[userenv.shared]
NODE_ENV = "production"
MAILGUN_DOMAIN = "mg.preferredbuildersusa.com"
BOT_EMAIL = "estimates@preferredbuildersusa.com"
PORT = "5000"
DISABLE_WHATSAPP_POLLER = "true"
DISABLE_WHATSAPP_WEBHOOK = "true"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
