# App
PORT=3001
NODE_ENV=production
ADMIN_PASSWORD=changeme123
SESSION_SECRET=your_random_session_secret_here

# Team WhatsApp Numbers (include country code)
OWNER_WHATSAPP=whatsapp:+1XXXXXXXXXX
JACKSON_WHATSAPP=whatsapp:+1XXXXXXXXXX
