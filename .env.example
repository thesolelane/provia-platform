# b============================================
# PREFERRED BUILDERS AI SYSTEM — ENV CONFIG
# Copy this to .env and fill in your values
# ============================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mailgun (Email receiving & sending)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.preferredbuildersusa.com
BOT_EMAIL=estimates@preferredbuildersusa.com
PB_FROM_EMAIL=estimates@preferredbuildersusa.com

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Hearth API
HEARTH_API_KEY=your_hearth_api_key_here
HEARTH_WEBHOOK_SECRET=your_hearth_webhook_secret

# Estimation platform (hearth or wave)
ESTIMATION_PLATFORM=hearth

# Wave API (only needed if using Wave instead of Hearth)
# WAVE_ACCESS_TOKEN=your_wave_access_token_here
# WAVE_BUSINESS_ID=your_wave_business_id

# App
PORT=5000
NODE_ENV=production
SESSION_SECRET=your_random_session_secret_here

# NOTE: Admin passwords are managed in the database, not here.
# Users (Anthony Cooper + Jackson Deaquino) are seeded automatically on first run.
# Default temp password: Preferred2024! — change after first login.

# App URL — the public URL where this app is accessible
# Used for generating PDF download links in WhatsApp messages
APP_URL=https://your-domain-or-ip.com

# Owner email — receives copies of proposals and contracts
OWNER_EMAIL=owner@preferredbuildersusa.com

# Webhook secret (auto-generated by setup.sh)
WEBHOOK_SECRET=

# Team WhatsApp Numbers (include country code)
OWNER_WHATSAPP=whatsapp:+1XXXXXXXXXX
JACKSON_WHATSAPP=whatsapp:+1XXXXXXXXXX
