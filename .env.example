# ============================================
# PREFERRED BUILDERS AI SYSTEM — ENV CONFIG
# Copy this file to .env and fill in values
# ============================================

PORT=5000
NODE_ENV=production
APP_URL=https://preferredbuilders.duckdns.org
SESSION_SECRET=your_random_session_secret_here

# ── Claude AI ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SMTP Email ───────────────────────────────
SMTP_USER=noreply@contactpreferred.com
SMTP_PASS=your_smtp_password
SMTP_HOST=smtp.contactpreferred.com
SMTP_PORT=587
BOT_EMAIL=estimates@preferredbuildersusa.com
OWNER_EMAIL=cooper@preferredbuildersusa.com

# ── Twilio (Live) ────────────────────────────
TWILIO_LIVE_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_LIVE_AUTH_TOKEN=your_live_auth_token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret
TWILIO_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX

# ── Team WhatsApp Numbers ─────────────────────
OWNER_WHATSAPP=whatsapp:+1XXXXXXXXXX
JACKSON_WHATSAPP=whatsapp:+1XXXXXXXXXX

# ── Backup ───────────────────────────────────
PBBKUPS=C:\Users\theso\Desktop\PBBKUPS

# ── Remote Update ────────────────────────────
UPDATE_SECRET=your_update_secret_here

# ── WhatsApp Poller ──────────────────────────
# Set to true to disable the WhatsApp poller (e.g. on Replit dev)
DISABLE_WHATSAPP_POLLER=false

# ── Perplexity AI (web search in AI bot) ─────
PERPLEXITY_API_KEY=pplx-...

# ── Measurement & Property Data ──────────────
# Microsoft Building Footprints — FREE, no key required, always active

# Google Solar API — roof area, pitch, bounding box (free 10k calls/mo)
# Get key: https://console.cloud.google.com → Enable Solar API → Create API key
GOOGLE_MAPS_API_KEY=AIzaSy...

# Hover — 3D property models, wall/siding measurements (paid per job)
# Register: https://developers.hover.to
# Step 1: Get client credentials from Hover developer portal
# Step 2: Complete OAuth flow to generate the access token
HOVER_CLIENT_ID=
HOVER_CLIENT_SECRET=
HOVER_ACCESS_TOKEN=

# EagleView — aerial roof measurement reports (paid per report)
# Register: https://developer.eagleview.com
EAGLEVIEW_CLIENT_ID=
EAGLEVIEW_CLIENT_SECRET=
