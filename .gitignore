# =====================================================
# .gitignore — PREFERRED BUILDERS AI SYSTEM
# =====================================================

# Environment & secrets — NEVER commit these
.env
.env.local
.env.production

# Local PM2 config with real credentials — stays on each machine, never committed
ecosystem.local.js

# Database — lives in /data, backed up separately
data/*.db
data/*.db-shm
data/*.db-wal

# Generated PDFs — regeneratable
outputs/*.pdf

# Uploaded files
uploads/*
!uploads/.gitkeep
!uploads/invoices/
!uploads/jobs/

# Backup archives — stored locally, never committed to git
backups/*.tar.gz

# Temporary files
tmp/*
!tmp/.gitkeep

# Dev scratch files
attached_assets/

# Node modules
node_modules/
client/node_modules/

# React build
client/build/

# Docker
docker/ssl/*.pem
docker/ssl/*.crt
docker/ssl/*.key

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Replit
.replit.nix
replit.nix
