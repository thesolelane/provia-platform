{
  "name": "preferred-builders-ai",
  "version": "1.5.0",
  "description": "Preferred Builders AI Contract & Estimation System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "lint": "eslint server/ client/src/ --ext .js,.jsx",
    "lint:fix": "eslint server/ client/src/ --ext .js,.jsx --fix",
    "format": "prettier --write \"server/**/*.js\" \"client/src/**/*.{js,jsx}\"",
    "format:check": "prettier --check \"server/**/*.js\" \"client/src/**/*.{js,jsx}\"",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --no-warn-ignored",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-fileupload": "^1.4.3",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "html-to-docx": "^1.8.0",
    "imapflow": "^1.2.13",
    "mailparser": "^3.9.4",
    "nodemailer": "^6.9.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^22.0.0",
    "resend": "^6.9.4",
    "twilio": "^5.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.0.0",
    "prettier": "^3.8.1"
  }
}
